{
  "name": "engrama-observatory",
  "version": "0.1.0",
  "private": true,
  "description": "Camada local de observabilidade cognitiva e plano de controle de modelos do Engrama.",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/server/index.ts",
    "build": "vite build",
    "start": "NODE_ENV=production node --import tsx src/server/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.15.29",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}

# Valores de override do Engrama.
# Formato: CHAVE=valor   (sem as chaves {{ }}, sem aspas, sem '#' no valor).
# O bootstrap já infere defaults; use este arquivo só para sobrescrever.

# --- INFERÍVEIS / OVERRIDE OPCIONAL ---
PROJETO=MeuProjeto
REPO_PATH=/caminho/absoluto/do/repo
ENGRAMA_VERSION=0.1.0
ORQUESTRADOR=Claude (Claude Code)
AUTORIDADE=Humano (voce@exemplo.com)
DATA=2026-01-01
FINALIDADE_DO_PROJETO=preencher na primeira abertura
STACK=Node + Postgres
DEV_URL=localhost:3000
CMD_DEV=npm run dev
CMD_BUILD=npm run build
CMD_TEST=npm test
CMD_E2E=N/A

# --- ADAPTADORES CONCRETOS / EXEMPLOS DO PACK (CONFIRME NO SEU AMBIENTE) ---
EXECUTOR=Codex
EXECUTOR_CMD=codex exec
MODELO_CRITICA=gpt-5.5
MODELO_EXECUTOR_PESADO=gpt-5.4
MODELO_EXECUTOR_LEVE=gpt-5.4-mini
